---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Taller de Francisco - Estilo JetBrains" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-950 text-gray-100 font-sans antialiased">
		<slot /> </body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		background: #0a0a0f;
	}
</style>